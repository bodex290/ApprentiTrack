# Database connection string
# For local SQLite (default – no config needed):
# DATABASE_URL=sqlite:///./server/db/app.db
#
# For hosted SQLite (e.g. Turso):
# DATABASE_URL=libsql://your-db.turso.io?authToken=...

DATABASE_URL=sqlite:///./server/db/app.db

# Server port
PORT=8000

# Allowed CORS origin (React frontend URL)
CORS_ORIGIN=http://localhost:5173

# ── LLM / AI Configuration ─────────────────────────────
# The system checks keys in order: AZURE_API_KEY → LITELLM_API_KEY → OPENAI_API_KEY.
# Only ONE provider needs to be configured.

# Option A: Azure OpenAI proxy (recommended for corporate environments)
AZURE_API_KEY=sk-your-azure-proxy-key
AZURE_BASE_URL=https://your-azure-proxy.example.com

# Option B: Direct OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-openai-key-here

# Option C: Self-hosted LiteLLM proxy
# LITELLM_API_KEY=sk-your-litellm-key
# LLM_API_BASE=https://your-litellm-proxy.example.com

# LLM model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# SSL verification (set to false for corporate proxies with self-signed certs)
# SSL_VERIFY=false


